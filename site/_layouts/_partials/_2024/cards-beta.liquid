{%- assign list = collections[component.filter] -%}
{%- assign i1 = 1 -%}

{%- if list -%}
  <section class="box box--alpha">
    {%- if component.title -%}
      <h2 class="box__title">
        {%- if component.href -%}
          <a href="{{ component.href }}">{{ component.title }}</a>
        {%- else -%}
          {{ component.title }}
        {%- endif -%}
      </h2>
    {%- endif -%}
    <ul class="box__grid">
      {%- for card in list -%}
        {% liquid
          assign now = 'now' | date: "%Y-%m-%d"
          assign cardDate = card.data.date | date: "%Y-%m-%d"
          if cardDate > now
            continue
          endif
          if component.limit and i1 > component.limit
            break
          endif
          if component.exclude
            assign tags = card.data.tags | join: ', '
            if tags contains component.exclude
              continue
            endif
          endif
        %}
        {%- unless component.exclude == 'title' and title == card.data.title -%}
          <li class="box__item">
            <a class="card card--alpha" href="{{ card.url }}">
              {%- if card.data.thumbnail -%}
                {% cldnry2 card.data.thumbnail.src card.data.thumbnail.alt 600 363 '400:100vw;600:50vw:37.5em;500:33vw:100em' %}
              {%- endif -%}
              {%- if card.data.title -%}
                <h3 class="card__title">{{ card.data.title }}</h3>
              {%- endif -%}
              {%- if card.data.tech -%}
                <span class="card__tags">
                  {%- for tech in card.data.tech -%}
                    <span class="card__tag">{{ tech }}</span>
                  {%- endfor -%}
                </span>
              {%- endif -%}
            </a>
          </li>
        {%- endunless -%}
        {%- assign i1 = i1 | plus: 1 -%}
      {%- endfor -%}
    </ul>
  </section>
  {% comment %} <section id="{{ cards2.filter }}" class="margin-top-beta margin-bottom-beta">
    <div class="wrapper wrapper--alpha grid padding">
      {% for card2 in card2List %}
        {% if cards2.limit and i2 > cards2.limit %}
          {% break %}
        {% endif %}
        {% unless cards2.exclude == 'true' or title contains card2.data.title %}
          <a class="card bg-lightish padding{% if cards2.other and card2.data.projects contains title %} border-alpha{% endif %}" href="{{ card2.url }}">
            <div class="tilt">
              <div class="tilt__inner">
                {% if card2.data.title %}
                  <header class="padding copy">
                    {% if card2.data.avatar %}
                      <div class="df aic">
                        {% if card2.data.avatar %}
                          <span class="db margin-right avatar">
                            {% assign altTextAvatar = card2.data.title | append: ' profile photo.' %}
                            {% cldnry card2.data.avatar altTextAvatar 60 60 %}
                          </span>
                        {% endif %}
                        <div>
                          <h3 class="fz-step-0 no-margin">{{ card2.data.title }}</h3>
                          <p class="fz-step--1 no-margin">{% if card2.data.position %}{{ card2.data.position }}{% endif %} {% if card2.data.company %} at {{ card2.data.company }}{% endif %}</p>
                        </div>
                      </div>
                    {% endif %}
                  </header>
                {% endif %}
                {% if card2.data.excerpt %}
                  <div class="copy padding fs-italic fz-step-0">{{ card2.data.excerpt | markdownify }}</div>
                {% else if card2.template.frontMatter.content %}
                  <div class="copy padding fs-italic fz-step-0">{{  card2.template.frontMatter.content | markdownify }}</div>
                {% endif %}
              </div>
            </div>
          </a>
          {% assign i2 = i2 | plus: 1 %}
        {% endunless %}
      {% endfor %}
      {% if cards2.desc %}
        <div class="card card--flex text-center padding">
          <div class="margin-auto">
            <div class="copy balance">{{ cards2.desc | markdownify }}</div>
            {% if cards2.cta2 %}
              <div class="margin-top">
                <a class="button" href="{{ cards2.cta2.href }}">{{ cards2.cta2.title }}</a>
              </div>
            {% endif %}
            {% if cards2.cta3 %}
              <div class="margin-top">
                <a class="tdu" href="{{ cards2.cta3.href }}">{{ cards2.cta3.title }}</a>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </section> {% endcomment %}
{% endif %}

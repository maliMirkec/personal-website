{%- liquid
  assign list = collections[component.filter] | sort: "date" | reverse
  assign i1 = 1
-%}

{%- if list -%}
  <section class="box">
    {%- if component.title -%}
      <h2 class="box__title">
        {%- if component.href -%}
          <a href="{{ component.href }}">{{ component.title }}</a>
        {%- else -%}
          {{ component.title }}
        {%- endif -%}
      </h2>
    {%- endif -%}
    <ul class="box__list">
      {%- for card in list -%}
        {%- liquid
          assign now = 'now' | date: "%Y-%m-%d"
          assign cardDate = card.data.date | date: "%Y-%m-%d"
          if cardDate > now
            continue
          endif
          if component.limit and i1 > component.limit
            break
          endif
          if component.exclude
            assign tags = card.data.tags | join: ', '
            if tags contains component.exclude
              continue
            endif
          endif
        -%}
        {%- unless component.exclude and page.url == card.url -%}
          <li class="box__item">
            {%- if card.data.title -%}
              <h3 class="box__subtitle"><a href="{{ card.url }}">{{ card.data.title }}</a></h3>
            {%- endif -%}
            {%- if card.data.publication or cardDate -%}
              <div class="box__tags">
                {%- if cardDate -%}
                  <time class="box__tag" datetime="{{ cardDate }}">{{ cardDate }}</time>
                {%- endif -%}
                {%- if card.data.publication -%}
                  <span class="box__tag">{{ card.data.publication }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </li>
        {%- endunless -%}
        {%- assign i1 = i1 | plus: 1 -%}
      {%- endfor -%}
    </ul>
  </section>
{%- endif -%}

{% if header %}
  <header class="header">
    <nav aria-label="Main">
      <ul class="header__list">
        {% if header.logo %}
          <li class="header__item header__item--alpha">
            <a class="header__link header__link--alpha" href="{{ header.logo.href }}">
              {% cldnry header.logo.src header.logo.alt header.logo.width header.logo.height false %}
            </a>
          </li>
        {% endif %}
        {% if header.menu %}
          {% for item in header.menu %}
            <li class="header__item">
              <a class="header__link header__link--beta" href="{{ item.href }}">{{ item.title }}</a>
            </li>
          {% endfor %}
        {% endif %}
      </ul>
    </nav>
  </header>
{% endif %}

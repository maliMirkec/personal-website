{%- assign lang = "en" -%}

<!DOCTYPE html>
<html lang="en" dir="ltr">
  {% include _partials/_general/head %}
  <body>
    {% include _partials/_2024/header %}
    <main id="main">
      {% block content %}
        {% if sections %}
          {% for section in sections %}
            {% include _partials/_2024/sections %}
          {% endfor %}
        {% endif %}
        {% if content != blank and content != '' %}
          {% include _partials/_2024/content-alpha %}
        {% endif %}
        {% if sections2 %}
          {% for section in sections2 %}
            {% include _partials/_2024/sections %}
          {% endfor %}
        {% endif %}
      {% endblock %}
      {% include _partials/_2024/lastfm %}
    </main>
    {% include _partials/_2024/footer %}
    {% include _partials/_assets/style %}
    {% include _partials/_assets/scripts %}
    {% include _partials/_assets/analytics %}
  </body>
</html>
